    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git merge *)"
    ]
  },
  "hooks": {
    "PreToolUse": []
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true
  },
  "mcpServers": {
    "codebase-memory-mcp": {
      "type": "stdio",
      "command": "$HOME/github.com/bpross/codebase-memory-mcp"
